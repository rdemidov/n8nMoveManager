# Docker Compose configuration. Copy this file to .env and replace both secrets.
# Generate AUTH_SIGNING_KEY with at least 32 random characters; do not reuse a password.
AUTH_ENABLED=true
AUTH_SIGNING_KEY=replace-with-a-random-secret-at-least-32-characters-long
AUTH_BOOTSTRAP_ADMIN_USER=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password-at-least-12-characters

# Host ports. API_PORT is bound to loopback only by compose.yaml.
WEB_PORT=4300
API_PORT=5107
